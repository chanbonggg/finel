# Spring Boot local development configuration. Copy to the repository root as .env.
SPRING_PROFILES_ACTIVE=devdb
FRONTEND_ORIGIN=http://localhost:3000
# Keep false while using an existing database that Flyway does not yet own.
# Enable only for a new Flyway-managed database or an approved baseline operation.
SPRING_FLYWAY_ENABLED=false

# Use a disposable local/development PostgreSQL database, never production.
DB_URL=jdbc:postgresql://localhost:5432/finel
DB_USERNAME=finel
DB_PASSWORD=change-me

# At least 32 bytes. Never expose this as NEXT_PUBLIC_*.
JWT_SECRET=change-me-at-least-32-bytes-long
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# Set these only when a local admin account needs to be created on startup.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Inquiry mail. Leave blank only when mail delivery is intentionally not tested.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_TO=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Signed server-side product-image upload.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=finel/products

# Optional Spring-to-Next cache invalidation. Keep both values blank to disable it.
NEXT_REVALIDATE_URL=
REVALIDATE_SECRET=
