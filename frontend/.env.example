# Next.js browser and server access to the local Spring API (non-secret values)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
SERVER_API_BASE_URL=http://localhost:8080

# Public site URL used for canonical and sitemap URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Spring backend
SPRING_PROFILES_ACTIVE=devdb
FRONTEND_ORIGIN=http://localhost:3000
DB_URL=jdbc:postgresql://localhost:5432/finel
DB_USERNAME=finel
DB_PASSWORD=change-me
JWT_SECRET=change-me-at-least-32-bytes-long
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_TO=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Cloudinary signed upload. Do not expose these as NEXT_PUBLIC_* values.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=finel/products
