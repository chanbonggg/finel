# Next.js local configuration. Copy this file to frontend/.env.local.
# Spring reads database, JWT, mail, and Cloudinary settings from the root .env.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
SERVER_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Needed only when Spring-to-Next cache invalidation is enabled.
# Never prefix this value with NEXT_PUBLIC_.
REVALIDATE_SECRET=change-me-to-a-long-random-secret
